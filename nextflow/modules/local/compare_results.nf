/*
Compare the transcript effects generated by multiple tools and
*/
process COMPARE_RESULTS {
    publishDir "${params.outdir}", mode: 'symlink'

    input:
    tuple val(meta), val(labels), path(result_files)
    path src_dir

    output:
    tuple val(meta), path("${meta.id}_comparison.xlsx"), emit: comparison

    script:
    // Create an a parameter for each entry in the results (eg --input tfx file.csv)
    def input_args = [labels, result_files].transpose()
        .collect { label, file -> "--input ${label} ${file}" }
        .join(' ')
    """    
    export PYTHONPATH="${src_dir}:\${PYTHONPATH:-}"
    echo 3
    python ${src_dir}/nomenclature_comparison/compare_results.py ${input_args} --out ${meta.id}_comparison.xlsx
    """
}