params {
    outdir = "results"
    
    variant_source_file_csv = "/tmp/work/variants.csv"

    // Python code created for this workflow 
    local_python_src_dir = "../python/src"

    // Transcript Effects configuration (general) 
    reference_fasta_file = "/opt/bioinformatics/Broad/Homo_sapiens_assembly19.fasta"
    uta_db_url = "postgresql://user:password@localhost:5432/uta/uta_20241220"
    seq_repo_dir = "/opt/bioinformatics/seqrepo/2024-12-20"
    annovar_dir = "/opt/bioinformatics/annovar"
    refseq_ccds_map = "/opt/bioinformatics/transcript_effects/refseq_to_ccds/GRCh37_refseq_ccds_mapping_20260324.csv"
    number_of_tfx_threads = 3

    // Transcript Effects configuration: respository location(s)
    // We may want to try more than one instance of Transcript Effects. For example, we may want to run the /main repository
    // and compare its output with the output generated by a development branch.      
    compbio_cgd_tx_eff_src_label_one = 'main'
    compbio_cgd_tx_eff_src_dir_one = "/tmp/work/repo/tfx_main/compbio-galaxy-wrappers/cgd_tx_eff/src"
    
    // If you want to run a second instance of transcript effecgts, define it here. 
    compbio_cgd_tx_eff_src_label_two = 'bio831_two_gdots'
    compbio_cgd_tx_eff_src_dir_two = "/tmp/work/repo/tfx_branch/compbio-galaxy-wrappers/cgd_tx_eff/src"

    // VEP configuration    
    vep_bin = "/opt/bioinformatics/ensembl-vep/vep"
    vep_data_dir = "/opt/bioinformatics/vep"
    vep_fasta_file = "${params.vep_data_dir}/homo_sapiens/75_GRCh37/Homo_sapiens.GRCh37.75.dna.primary_assembly.fa.gz"   
}
